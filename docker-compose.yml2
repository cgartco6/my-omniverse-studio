version: '3.8'

services:
  backend:
    build: ./backend
    ports:
      - "8000:8000"
    volumes:
      - ./backend:/app
      - studio_memory_vault:/app/.memory_vault
    environment:
      - ENV=development
    restart: always

  frontend:
    build: ./frontend
    ports:
      - "3000:3000"
    volumes:
      - ./frontend:/src
    environment:
      - REACT_APP_API_URL=http://localhost:8000
    restart: always

volumes:
  studio_memory_vault:
